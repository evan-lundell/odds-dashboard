PORT=3001
MONGODB_URI=mongodb://localhost:27017/odds-dashboard
ODDS_API_KEY=your_api_key_here
ODDS_POLL_INTERVAL_MS=30000

# Set to "true" to use simulated mock data instead of the real Odds API.
# Games will progress through upcoming -> live -> completed on a timer
# so you can test the full betting + settlement flow locally.
MOCK_API=true
